# ==============================================================================
# .gitignore for Codex-First Academic Projects
# ==============================================================================

# LaTeX build artifacts
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.log
*.nav
*.out
*.snm
*.toc
*.vrb
*.synctex.gz
*.run.xml
*-blx.bib

# Compiled PDFs (uncomment to track specific PDFs)
# *.pdf

# Python
__pycache__/
*.pyc
*.pyo

# R
.Rproj.user/
.Rhistory
.RData
.Rdata

# OS files
.DS_Store
Thumbs.db

# Codex/local assistant files (not shared across machines)
.codex/
AGENTS.local.md

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Quarto rendering artifacts
/.quarto/

# Output artifacts — uncomment lines below based on your preference
# *.rds
# output/**/*.rds
